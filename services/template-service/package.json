{
  "name": "@ecommerce/template-service",
  "version": "1.0.0",
  "description": "Template for microservices",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "docker:build": "docker build -t template-service .",
    "docker:run": "docker run -p 3000:3000 template-service"
  },
  "dependencies": {
    "@ecommerce/common": "1.0.0",
    "@ecommerce/types": "1.0.0",
    "fastify": "^4.24.3",
    "@fastify/helmet": "^11.0.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^8.0.3",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "amqplib": "^0.10.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
